<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('partials/head') %>
    <title>Forgot Password | Libas-e-Ikhlaq</title>
</head>
<body class="auth-page">

    <div class="container-fluid p-0">
        <div class="row g-0 min-vh-100">
            
            <div class="col-12 col-lg-6 auth-image-side d-flex flex-column justify-content-center align-items-center text-center p-5" style="background: linear-gradient(rgba(0,0,0,0.5), rgba(0,0,0,0.7)), url('/washnwear-premium.png') center/cover no-repeat; min-height: 40vh;">
                <h1 class="auth-brand-title text-white">LIBAS-E-IKHLAQ</h1>
                <p class="auth-brand-tagline text-white">Elevating everyday style with premium unstitched fabrics and signature fragrances.</p>
            </div>

            <div class="col-12 col-lg-6 auth-form-side d-flex flex-column justify-content-center position-relative p-4 p-md-5 bg-white">
                <a href="/login" class="back-btn mb-4 d-inline-block text-decoration-none text-dark fw-bold"><i class="fa-solid fa-arrow-left"></i> Back to Login</a>

                <div class="auth-form-wrapper mx-auto" style="max-width: 450px; width: 100%;">
                    <h2 class="mb-2">Recover Password</h2>
                    <p class="text-muted mb-4">Enter your email address and we'll send you a secure link to reset your password.</p>

                    <% if (locals.success_msg && success_msg.length > 0) { %>
                        <div class="alert alert-success"><%= success_msg %></div>
                    <% } %>
                    <% if (locals.error_msg && error_msg.length > 0) { %>
                        <div class="alert alert-danger"><%= error_msg %></div>
                    <% } %>

                    <form action="/forgot-password" method="POST">
                        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                        <div class="mb-4">
                            <label for="recovery-email" class="form-label">Email Address</label>
                            <input type="email" class="form-control" id="recovery-email" name="email" required placeholder="e.g. customer@mail.com">
                        </div>
                        <button type="submit" class="btn btn-dark w-100 py-2 fw-bold" style="background-color: var(--brand-orange); border-color: var(--brand-orange);">SEND RESET LINK</button>
                    </form>

                    <div class="text-center mt-4">
                        Remember your password? <a href="/login" class="fw-bold text-decoration-none" style="color: var(--brand-orange);">Log In</a>
                    </div>
                </div>
            </div>
        </div>
    </div>

</body>
</html>
