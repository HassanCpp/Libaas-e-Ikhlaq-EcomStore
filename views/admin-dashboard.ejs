<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('partials/head') %>
    <title>Admin Dashboard | Libas-e-Ikhlaq</title>
</head>
<body class="admin-bg">

    <nav class="navbar navbar-expand-lg admin-navbar shadow-sm">
        <div class="container-fluid px-4 align-items-center">
            
            <a href="/admin" class="text-decoration-none d-flex align-items-center gap-3">
    <img src="/logo.png" alt="Libas e ikhlaq Logo" style="height: 50px;">
    
    <div class="d-flex flex-column align-items-center justify-content-center" style="margin-top: 3px;">
        <span dir="rtl" style="font-family: 'Noto Nastaliq Urdu', serif; font-size: 20px; color: #333; line-height: 0.8; margin-bottom: 13px;">لباس اخلاق</span>
        <span style="font-family: 'Montserrat', sans-serif; font-size: 13px; font-weight: 700; letter-spacing: 2px; color: #333;">
            LIBAS-E-IKHLAQ <span style="color: var(--brand-orange);">ADMIN</span>
        </span>
    </div>
 </a>

            <div class="d-flex gap-4 align-items-center mt-2 mt-lg-0">
                <span class="text-muted small fw-bold" style="letter-spacing: 1px; text-transform: uppercase;">
                    Hi, <%= currentUser.name.split(' ')[0] %>
                </span>
                <a href="/" class="btn btn-sm btn-outline-dark" style="border-radius: 2px; font-weight: 600; letter-spacing: 1px;" target="_blank">VIEW STORE</a>
                <a href="/logout" style="color: var(--brand-orange); font-size: 18px;" title="Logout"><i class="fa-solid fa-arrow-right-from-bracket"></i></a>
            </div>
        </div>
    </nav>

    <div class="container mt-5 mb-5">
        
        <ul class="nav nav-tabs mb-4" style="border-bottom: 2px solid #eee;">
            <li class="nav-item">
                <a class="nav-link active fw-bold text-dark border-bottom-0" style="border-top: 3px solid #111;" href="/admin">Products Inventory</a>
            </li>
            <li class="nav-item">
                <a class="nav-link fw-bold text-muted" href="/admin/orders">Customer Orders</a>
            </li>
            <li class="nav-item">
                <a class="nav-link fw-bold text-muted" href="/admin/analytics">Sales & Inventory Analytics</a>
            </li>
            <li class="nav-item">
                <a class="nav-link fw-bold text-muted" href="/admin/users">Customer Directory</a>
            </li>
            <li class="nav-item">
                <a class="nav-link fw-bold text-muted" href="/admin/reviews">Reviews Moderation</a>
            </li>
        </ul>

        <div class="d-flex justify-content-between align-items-center mb-4 pb-2 border-bottom flex-wrap gap-3">
            <h2 class="fw-light m-0" style="color: #111; letter-spacing: 1px;">Inventory Overview</h2>
            <a href="/admin/products/add" class="btn admin-btn-primary px-4 py-2 fw-bold shadow-sm">
                <i class="fa-solid fa-plus me-2"></i> NEW PRODUCT
            </a>
        </div>

        <% if (success_msg && success_msg.length > 0) { %>
            <div class="alert alert-success border-0 shadow-sm" style="background-color: #f4fdf8; color: #1e8e3e; border-left: 4px solid #1e8e3e !important;">
                <i class="fa-solid fa-check-circle me-2"></i><%= success_msg %>
            </div>
        <% } %>

        <div class="card admin-card">
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table admin-table mb-0">
                        <thead>
                            <tr>
                                <th class="ps-4">Product</th>
                                <th>Category</th>
                                <th>Price</th>
                                <th>Stock</th>
                                <th class="text-end pe-4">Manage</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% if (products && products.length > 0) { %>
                                <% products.forEach(product => { %>
                                    <tr>
                                        <td class="ps-4">
                                            <div class="d-flex align-items-center gap-3">
                                                <img src="<%= product.image %>" alt="<%= product.name %>" style="width: 50px; height: 50px; object-fit: cover; border-radius: 4px; border: 1px solid #eee;">
                                                <span class="fw-bold text-dark" style="font-size: 14px;"><%= product.name %></span>
                                            </div>
                                        </td>
                                        <td class="text-muted" style="font-size: 14px; text-transform: capitalize;"><%= product.category %></td>
                                        <td class="fw-bold text-dark" style="font-size: 14px;">Rs. <%= product.price.toLocaleString() %></td>
                                        <td>
                                            <span class="stock-badge <%= product.stock > 5 ? 'stock-high' : 'stock-low' %>">
                                                <%= product.stock %> in stock
                                            </span>
                                        </td>
                                        <td class="text-end pe-4">
                                            <a href="/admin/products/edit/<%= product._id %>" class="btn btn-sm btn-light text-dark fw-bold me-2 border" style="border-radius: 2px;"><i class="fa-solid fa-pen"></i></a>
                                            <form action="/admin/products/delete/<%= product._id %>" method="POST" class="d-inline" onsubmit="return confirm('Delete this product permanently?');">
                                                <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                                                <button type="submit" class="btn btn-sm btn-light text-danger fw-bold border" style="border-radius: 2px;"><i class="fa-solid fa-trash"></i></button>
                                            </form>
                                        </td>
                                    </tr>
                                <% }) %>
                            <% } else { %>
                                <tr>
                                    <td colspan="5" class="text-center py-5 text-muted">
                                        <p class="mb-0">Your catalog is currently empty.</p>
                                    </td>
                                </tr>
                            <% } %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</body>
</html>