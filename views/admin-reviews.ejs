<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('partials/head') %>
    <title>Reviews Moderation | Libas-e-Ikhlaq Admin</title>
</head>
<body class="admin-bg">

    <nav class="navbar navbar-expand-lg admin-navbar shadow-sm">
        <div class="container-fluid px-4 align-items-center">
            <a href="/admin" class="text-decoration-none d-flex align-items-center gap-3">
                <img src="/logo.png" alt="Libas e ikhlaq Logo" style="height: 50px;">
                <div class="d-flex flex-column align-items-center justify-content-center" style="margin-top: 3px;">
                    <span dir="rtl" style="font-family: 'Noto Nastaliq Urdu', serif; font-size: 20px; color: #333; line-height: 0.8; margin-bottom: 13px;">لباس اخلاق</span>
                    <span style="font-family: 'Montserrat', sans-serif; font-size: 13px; font-weight: 700; letter-spacing: 2px; color: #333;">
                        LIBAS-E-IKHLAQ <span style="color: var(--brand-orange);">ADMIN</span>
                    </span>
                </div>
            </a>

            <div class="d-flex gap-4 align-items-center mt-2 mt-lg-0">
                <span class="text-muted small fw-bold" style="letter-spacing: 1px; text-transform: uppercase;">
                    Hi, <%= currentUser.name.split(' ')[0] %>
                </span>
                <a href="/" class="btn btn-sm btn-outline-dark" style="border-radius: 2px; font-weight: 600; letter-spacing: 1px;" target="_blank">VIEW STORE</a>
                <a href="/logout" style="color: var(--brand-orange); font-size: 18px;" title="Logout"><i class="fa-solid fa-arrow-right-from-bracket"></i></a>
            </div>
        </div>
    </nav>

    <div class="container mt-5 mb-5">
        
        <!-- Navigation Tabs -->
        <ul class="nav nav-tabs mb-4" style="border-bottom: 2px solid #eee;">
            <li class="nav-item">
                <a class="nav-link fw-bold text-muted" href="/admin">Products Inventory</a>
            </li>
            <li class="nav-item">
                <a class="nav-link fw-bold text-muted" href="/admin/orders">Customer Orders</a>
            </li>
            <li class="nav-item">
                <a class="nav-link fw-bold text-muted" href="/admin/analytics">Sales & Inventory Analytics</a>
            </li>
            <li class="nav-item">
                <a class="nav-link fw-bold text-muted" href="/admin/users">Customer Directory</a>
            </li>
            <li class="nav-item">
                <a class="nav-link active fw-bold text-dark border-bottom-0" style="border-top: 3px solid #111;" href="/admin/reviews">Reviews Moderation</a>
            </li>
        </ul>

        <div class="d-flex justify-content-between align-items-center mb-4 pb-2 border-bottom flex-wrap gap-3">
            <h2 class="fw-light m-0" style="color: #111; letter-spacing: 1px;">Reviews Moderation</h2>
            <div class="d-flex gap-2">
                <input type="text" id="review-search-input" placeholder="Search by product or email..." class="form-control form-control-sm" style="max-width: 280px; border-radius: 2px; font-size: 13px; font-family: 'Montserrat', sans-serif;">
            </div>
        </div>

        <!-- Success & Error Alert Panels -->
        <% if (success_msg && success_msg.length > 0) { %>
            <div class="alert alert-success border-0 shadow-sm mb-4" style="background-color: #f4fdf8; color: #1e8e3e; border-left: 4px solid #1e8e3e !important;">
                <i class="fa-solid fa-check-circle me-2"></i><%= success_msg %>
            </div>
        <% } %>
        <% if (error_msg && error_msg.length > 0) { %>
            <div class="alert alert-danger border-0 shadow-sm mb-4">
                <i class="fa-solid fa-triangle-exclamation me-2"></i><%= error_msg %>
            </div>
        <% } %>

        <div class="card admin-card">
            <div class="table-responsive">
                <table class="table admin-table align-middle mb-0" id="reviews-table">
                    <thead>
                        <tr>
                            <th>No.</th>
                            <th>Product</th>
                            <th>Reviewer</th>
                            <th>Rating</th>
                            <th style="width: 40%;">Comment</th>
                            <th>Date</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if (reviews.length > 0) { %>
                            <% reviews.forEach((review, index) => { %>
                                <tr class="review-row">
                                    <td class="text-muted"><%= index + 1 %></td>
                                    <td>
                                        <% if (review.product) { %>
                                            <strong class="review-product-name" style="font-size: 13.5px;"><%= review.product.name %></strong>
                                            <div class="text-capitalize text-muted" style="font-size: 11px;"><%= review.product.category %></div>
                                        <% } else { %>
                                            <span class="text-muted italic">[Deleted Product]</span>
                                        <% } %>
                                    </td>
                                    <td>
                                        <strong style="font-size: 13.5px;"><%= review.userName %></strong>
                                        <div class="review-user-email text-muted" style="font-size: 11px;"><%= review.user ? review.user.email : 'Guest' %></div>
                                    </td>
                                    <td>
                                        <div class="text-warning d-flex gap-1" style="font-size: 12px;" title="<%= review.rating %>/5">
                                            <% for(let i = 1; i <= 5; i++) { %>
                                                <i class="<%= i <= review.rating ? 'fa-solid' : 'fa-regular' %> fa-star"></i>
                                            <% } %>
                                        </div>
                                    </td>
                                    <td>
                                        <p class="mb-0 text-muted" style="font-size: 13px; line-height: 1.5; max-height: 60px; overflow-y: auto;">
                                            <%= review.comment %>
                                        </p>
                                    </td>
                                    <td style="font-size: 12px; white-space: nowrap;">
                                        <%= new Date(review.createdAt).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' }) %>
                                    </td>
                                    <td class="text-end">
                                        <form action="/admin/reviews/delete/<%= review._id %>" method="POST" class="d-inline" onsubmit="return confirm('Are you sure you want to delete this review? This action cannot be undone.');">
                                            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                                            <button type="submit" class="btn btn-sm btn-outline-danger px-3 py-1.5 fw-bold d-inline-flex align-items-center gap-1" style="font-size: 12px; border-radius: 2px;">
                                                <i class="fa-regular fa-trash-can"></i> DELETE
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                            <% }) %>
                        <% } else { %>
                            <tr>
                                <td colspan="7" class="text-center py-5 text-muted">No product reviews submitted yet.</td>
                            </tr>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>

    </div>

    <p class="text-center mt-4 mb-5 text-muted" style="letter-spacing: 1px; font-size: 11px;">
        &copy; 2026 LIBAS-E-IKHLAQ BOUTIQUE MANAGEMENT
    </p>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        document.addEventListener("DOMContentLoaded", function() {
            const searchInput = document.getElementById("review-search-input");
            const rows = document.querySelectorAll(".review-row");

            searchInput.addEventListener("keyup", function() {
                const query = searchInput.value.toLowerCase().trim();
                rows.forEach(row => {
                    const productNameEl = row.querySelector(".review-product-name");
                    const productName = productNameEl ? productNameEl.textContent.toLowerCase() : "";
                    
                    const userEmailEl = row.querySelector(".review-user-email");
                    const userEmail = userEmailEl ? userEmailEl.textContent.toLowerCase() : "";

                    const reviewerName = row.cells[2].querySelector("strong").textContent.toLowerCase();

                    if (productName.includes(query) || userEmail.includes(query) || reviewerName.includes(query)) {
                        row.style.display = "";
                    } else {
                        row.style.display = "none";
                    }
                });
            });
        });
    </script>
</body>
</html>
