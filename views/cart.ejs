<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('partials/head') %>
    <title>Shopping Cart | Libas-e-Ikhlaq</title>
    <style>
        .cart-wrapper {
            max-width: 1100px;
            margin: 40px auto;
            padding: 0 20px;
        }
        .cart-table th {
            font-family: 'Montserrat', sans-serif;
            font-weight: 600;
            letter-spacing: 1px;
            font-size: 14px;
            text-transform: uppercase;
            padding: 15px;
        }
        .cart-table td {
            vertical-align: middle;
            padding: 15px;
        }
        .cart-img {
            max-width: 80px;
            border-radius: 4px;
            border: 1px solid #eaeaea;
        }
        .cart-product-title {
            font-weight: 600;
            color: #111;
            text-decoration: none;
        }
        .cart-product-title:hover {
            color: var(--brand-orange);
        }
        .qty-controls {
            display: flex;
            align-items: center;
            border: 1px solid #ddd;
            border-radius: 4px;
            width: fit-content;
            overflow: hidden;
        }
        .qty-controls button {
            border: none;
            background: #f8f9fa;
            width: 30px;
            height: 35px;
            cursor: pointer;
            font-size: 16px;
            transition: background 0.2s;
        }
        .qty-controls button:hover {
            background: #e9ecef;
        }
        .qty-display {
            width: 40px;
            text-align: center;
            font-weight: 600;
            font-size: 14px;
        }
        .cart-summary {
            background-color: #fcfcfc;
            border: 1px solid #f0f0f0;
            border-radius: 6px;
            padding: 30px;
            margin-top: 20px;
        }
        .summary-title {
            font-family: 'Montserrat', sans-serif;
            font-weight: 700;
            margin-bottom: 20px;
            font-size: 1.2rem;
            border-bottom: 1px solid #eaeaea;
            padding-bottom: 10px;
        }
        .summary-row {
            display: flex;
            justify-content: space-between;
            margin-bottom: 15px;
            font-size: 15px;
        }
        .summary-total {
            font-size: 1.4rem;
            font-weight: 700;
            color: var(--brand-orange);
            border-top: 1px solid #eaeaea;
            padding-top: 15px;
            margin-top: 15px;
        }
        .btn-checkout {
            background-color: #111;
            color: #fff;
            border: none;
            width: 100%;
            padding: 14px;
            font-weight: 700;
            letter-spacing: 1px;
            border-radius: 4px;
            margin-top: 20px;
            transition: all 0.3s;
            text-decoration: none;
            display: block;
            text-align: center;
        }
        .btn-checkout:hover {
            background-color: var(--brand-orange);
            color: #fff;
            transform: translateY(-2px);
        }
        .empty-cart-box {
            text-align: center;
            padding: 80px 20px;
        }
    </style>
</head>
<body>
    <%- include('partials/header') %>
    <%- include('partials/nav') %>

    <div class="cart-wrapper">
        <h1 class="page-title">Shopping Cart</h1>

        <!-- Messages -->
        <% if (success_msg && success_msg.length > 0) { %>
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                <%= success_msg %>
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        <% } %>
        <% if (error_msg && error_msg.length > 0) { %>
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                <%= error_msg %>
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        <% } %>

        <% if (cartItems.length > 0) { %>
            <div class="row">
                <!-- Cart Items Table -->
                <div class="col-lg-8">
                    <div class="table-responsive">
                        <table class="table cart-table">
                            <thead>
                                <tr class="table-light">
                                    <th colspan="2">Product</th>
                                    <th>Price</th>
                                    <th>Quantity</th>
                                    <th>Total</th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody>
                                <% cartItems.forEach(item => { %>
                                    <tr>
                                        <td>
                                            <a href="/products/<%= item.product._id %>">
                                                <img src="<%= item.product.image %>" alt="<%= item.product.name %>" class="cart-img">
                                            </a>
                                        </td>
                                        <td>
                                            <a href="/products/<%= item.product._id %>" class="cart-product-title">
                                                <%= item.product.name %>
                                            </a>
                                            <div class="text-muted small mt-1">Category: <%= item.product.category %></div>
                                            <% if (item.size) { %>
                                                <div class="text-muted small mt-1">Size: <strong style="color: var(--brand-orange);"><%= item.size %></strong></div>
                                            <% } %>
                                        </td>
                                        <td>
                                            <% if (item.product.discountPrice && item.product.discountPrice > 0 && item.product.discountPrice < item.product.price) { %>
                                                <span class="text-muted text-decoration-line-through d-block" style="font-size: 0.8em; font-weight: normal;">PKR <%= item.product.price.toLocaleString() %></span>
                                                PKR <%= item.product.discountPrice.toLocaleString() %>
                                            <% } else { %>
                                                PKR <%= item.product.price.toLocaleString() %>
                                            <% } %>
                                        </td>
                                        <td>
                                            <div class="qty-controls">
                                                <!-- Minus Button Form -->
                                                <form action="/cart/update" method="POST" class="m-0">
                                                    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                                                    <input type="hidden" name="productId" value="<%= item.product._id %>">
                                                    <input type="hidden" name="size" value="<%= item.size || '' %>">
                                                    <input type="hidden" name="quantity" value="<%= item.quantity - 1 %>">
                                                    <button type="submit">-</button>
                                                </form>
                                                
                                                <span class="qty-display"><%= item.quantity %></span>
                                                
                                                <!-- Plus Button Form -->
                                                <form action="/cart/update" method="POST" class="m-0">
                                                    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                                                    <input type="hidden" name="productId" value="<%= item.product._id %>">
                                                    <input type="hidden" name="size" value="<%= item.size || '' %>">
                                                    <input type="hidden" name="quantity" value="<%= item.quantity + 1 %>">
                                                    <button type="submit">+</button>
                                                </form>
                                            </div>
                                        </td>
                                        <td class="fw-bold">PKR <%= item.totalItemPrice.toLocaleString() %></td>
                                        <td>
                                            <!-- Remove Item Form -->
                                            <form action="/cart/remove" method="POST" class="m-0">
                                                <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                                                <input type="hidden" name="productId" value="<%= item.product._id %>">
                                                <input type="hidden" name="size" value="<%= item.size || '' %>">
                                                <button type="submit" class="btn btn-sm btn-link text-danger p-0" title="Remove Item">
                                                    <i class="fa-solid fa-trash-can fs-5"></i>
                                                </button>
                                            </form>
                                        </td>
                                    </tr>
                                <% }) %>
                            </tbody>
                        </table>
                    </div>

                    <div class="mt-4">
                        <a href="/products" class="btn btn-outline-dark px-4 py-2 fw-bold">
                            <i class="fa-solid fa-arrow-left me-2"></i> Continue Shopping
                        </a>
                    </div>
                </div>

                <!-- Order Summary Sidebar -->
                <div class="col-lg-4">
                    <div class="cart-summary">
                        <h2 class="summary-title">Summary</h2>
                        <div class="summary-row text-muted">
                            <span>Subtotal</span>
                            <span>PKR <%= subtotal.toLocaleString() %></span>
                        </div>
                        <div class="summary-row text-muted">
                            <span>Delivery fee</span>
                            <span>FREE</span>
                        </div>
                        <div class="summary-row summary-total">
                            <span>Total</span>
                            <span>PKR <%= subtotal.toLocaleString() %></span>
                        </div>
                        <a href="/checkout" class="btn-checkout">
                            PROCEED TO CHECKOUT
                        </a>
                    </div>
                </div>
            </div>
        <% } else { %>
            <div class="empty-cart-box">
                <i class="fa-solid fa-bag-shopping text-muted fa-4x mb-4"></i>
                <h3>Your shopping cart is empty</h3>
                <p class="text-muted mt-2 mb-4">Looks like you haven't added any products to your cart yet.</p>
                <a href="/products" class="btn btn-dark px-5 py-3 fw-bold">SHOP THE CATALOG</a>
            </div>
        <% } %>
    </div>

    <%- include('partials/footer') %>
</body>
</html>
