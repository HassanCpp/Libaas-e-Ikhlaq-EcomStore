<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Libas-e-Ikhlaq | Men's Clothing</title>
    <link rel="stylesheet" href="/css/style.css">
    <script src="/js/script.js" defer></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;600;700&family=Noto+Nastaliq+Urdu:wght@400;700&display=swap" rel="stylesheet">
</head>
<body>

    <%- include('partials/header') %>
    <%- include('partials/nav') %>

    <section class="info-hero">
        <h1 dir="rtl">لباس جوبنےآپ کی شناخت</h1>
        <p>Discover our premium range of unstitched fabrics, signature fragrances, and curated accessories designed to elevate your everyday style.</p>
        <button class="btn-primary">View Collections</button>
    </section>

    <section class="carousel-section">
        
        <div class="carousel-wrapper" id="heroCarousel">
            
            <div class="carousel-slide slide-1">
                <div class="carousel-content">
                    <h2>WINTER CLEARANCE SALE</h2>
                    <p>FLAT 25% & 50% OFF on Selected Items</p>
                    <button class="btn-dark">Shop The Sale</button>
                </div>
            </div>

            <div class="carousel-slide slide-2">
                <div class="carousel-content dark-text-content">
                    <h2>THE SPRING / SUMMER '26 EDIT</h2>
                    <p>Step into the new season with our lightweight, breathable fabrics.</p>
                    <button class="btn-dark">Explore New Arrivals</button>
                </div>
            </div>

            <div class="carousel-slide slide-3">
                <div class="carousel-content">
                    <h2>MASTER THE ART OF BESPOKE</h2>
                    <p>Premium Egyptian cottons and wash-and-wear fabrics.</p>
                    <button class="btn-dark">Shop Unstitched</button>
                </div>
            </div>

            <div class="carousel-slide slide-4">
                <div class="carousel-content">
                    <h2>LEAVE A LASTING IMPRESSION</h2>
                    <p>Complete your attire with our signature men's fragrances.</p>
                    <button class="btn-dark">Discover Fragrances</button>
                </div>
            </div>

        </div>

        </div> <div class="carousel-dots" id="carouselDots"></div>

    </section> 


    <section class="products-section">
        <h2 style="font-family: 'Montserrat', sans-serif; font-weight: 700; letter-spacing: 2px; text-transform: uppercase; color: #111; margin-bottom: 30px; text-align: center;">NEW ARRIVALS</h2>
        <div class="product-grid">
            <% newArrivals.forEach(product => { %>
                <div class="product-card">
                    <div class="product-image-container">
                        <a href="/products/<%= product._id %>">
                            <img src="<%= product.image %>" alt="<%= product.name %>" class="product-image">
                        </a>
                    </div>
                    <div class="product-info">
                        <h3 class="product-name">
                            <a href="/products/<%= product._id %>" style="text-decoration: none; color: inherit;">
                                <%= product.name %>
                            </a>
                        </h3>
                        <p class="product-price">
                            <% if (product.discountPrice && product.discountPrice > 0 && product.discountPrice < product.price) { %>
                                <span class="text-muted text-decoration-line-through me-2" style="font-size: 0.85em; font-weight: normal; color: #888; text-decoration: line-through;">PKR <%= product.price.toLocaleString() %></span>
                                <span style="color: var(--brand-orange); font-weight: 700;">PKR <%= product.discountPrice.toLocaleString() %></span>
                            <% } else { %>
                                PKR <%= product.price.toLocaleString() %>
                            <% } %>
                        </p>
                        <% if (product.category === 'kurta-pajama' || product.category === 'waistcoats') { %>
                            <a href="/products/<%= product._id %>" class="add-to-cart-btn text-decoration-none" style="display:block; text-align:center; font-weight:bold;">
                                <i class="fa-solid fa-ruler-combined"></i> SELECT SIZE
                            </a>
                        <% } else { %>
                            <form action="/cart/add" method="POST" style="width: 100%;">
                                <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                                <input type="hidden" name="productId" value="<%= product._id %>">
                                <input type="hidden" name="quantity" value="1">
                                <button type="submit" class="add-to-cart-btn w-100" style="font-weight:bold; cursor:pointer;">
                                    <i class="fa-solid fa-cart-shopping"></i> ADD TO CART
                                </button>
                            </form>
                        <% } %>
                    </div>
                </div>
            <% }) %>
        </div>
    </section>

    <section class="products-section" style="background-color: #fcfcfc; border-top: 1px solid #f0f0f0; border-bottom: 1px solid #f0f0f0; padding: 60px 5%;">
        <h2 style="font-family: 'Montserrat', sans-serif; font-weight: 700; letter-spacing: 2px; text-transform: uppercase; color: #111; margin-bottom: 30px; text-align: center;">SPECIAL OFFERS</h2>
        <div class="product-grid">
            <% featuredOffers.forEach(product => { %>
                <div class="product-card" style="position: relative;">
                    <% if (product.discountPrice && product.discountPrice > 0 && product.discountPrice < product.price) { %>
                        <% const pct = Math.round(((product.price - product.discountPrice) / product.price) * 100); %>
                        <div class="sale-badge" style="position: absolute; top: 10px; left: 10px; background-color: var(--brand-orange); color: #fff; padding: 4px 8px; font-size: 11px; font-weight: 700; border-radius: 4px; z-index: 10; letter-spacing: 0.5px;">SAVE <%= pct %>%</div>
                    <% } %>
                    <div class="product-image-container">
                        <a href="/products/<%= product._id %>">
                            <img src="<%= product.image %>" alt="<%= product.name %>" class="product-image">
                        </a>
                    </div>
                    <div class="product-info">
                        <h3 class="product-name">
                            <a href="/products/<%= product._id %>" style="text-decoration: none; color: inherit;">
                                <%= product.name %>
                            </a>
                        </h3>
                        <p class="product-price">
                            <% if (product.discountPrice && product.discountPrice > 0 && product.discountPrice < product.price) { %>
                                <span class="text-muted text-decoration-line-through me-2" style="font-size: 0.85em; font-weight: normal; color: #888; text-decoration: line-through;">PKR <%= product.price.toLocaleString() %></span>
                                <span style="color: var(--brand-orange); font-weight: 700;">PKR <%= product.discountPrice.toLocaleString() %></span>
                            <% } else { %>
                                PKR <%= product.price.toLocaleString() %>
                            <% } %>
                        </p>
                        <% if (product.category === 'kurta-pajama' || product.category === 'waistcoats') { %>
                            <a href="/products/<%= product._id %>" class="add-to-cart-btn text-decoration-none" style="display:block; text-align:center; font-weight:bold;">
                                <i class="fa-solid fa-ruler-combined"></i> SELECT SIZE
                            </a>
                        <% } else { %>
                            <form action="/cart/add" method="POST" style="width: 100%;">
                                <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                                <input type="hidden" name="productId" value="<%= product._id %>">
                                <input type="hidden" name="quantity" value="1">
                                <button type="submit" class="add-to-cart-btn w-100" style="font-weight:bold; cursor:pointer;">
                                    <i class="fa-solid fa-cart-shopping"></i> ADD TO CART
                                </button>
                            </form>
                        <% } %>
                    </div>
                </div>
            <% }) %>
        </div>
    </section>
    <section class="testimonials-section">
        <h2>WHAT OUR CLIENTS SAY</h2>
        
        <div class="testimonials-grid">
            <div class="testimonial-card">
                <div class="stars">
                    <i class="fa-solid fa-star"></i>
                    <i class="fa-solid fa-star"></i>
                    <i class="fa-solid fa-star"></i>
                    <i class="fa-solid fa-star"></i>
                    <i class="fa-solid fa-star"></i>
                </div>
                <p class="quote">"The premium Egyptian cotton is exactly as described. The fabric feels incredibly soft and drapes perfectly after tailoring. Highly recommended."</p>
                <p class="customer-name">- Ahmed R.</p>
            </div>

            <div class="testimonial-card">
                <div class="stars">
                    <i class="fa-solid fa-star"></i>
                    <i class="fa-solid fa-star"></i>
                    <i class="fa-solid fa-star"></i>
                    <i class="fa-solid fa-star"></i>
                    <i class="fa-solid fa-star"></i>
                </div>
                <p class="quote">"I ordered the wash-and-wear unstitched fabric for daily office use. The quality is outstanding and the delivery was very prompt."</p>
                <p class="customer-name">- Salman T.</p>
            </div>

            <div class="testimonial-card">
                <div class="stars">
                    <i class="fa-solid fa-star"></i>
                    <i class="fa-solid fa-star"></i>
                    <i class="fa-solid fa-star"></i>
                    <i class="fa-solid fa-star"></i>
                    <i class="fa-solid fa-star-half-stroke"></i>
                </div>
                <p class="quote">"Oud E Khaas has become my new signature scent. It lasts all day and has a very rich, traditional profile without being overpowering."</p>
                <p class="customer-name">- Usman K.</p>
            </div>
        </div>
    </section>

    <section class="newsletter-section">
        <div class="newsletter-content">
            <h2>JOIN THE CLUB</h2>
            <p>Subscribe to our newsletter to receive exclusive offers, early access to new collections, and 10% off your first unstitched order.</p>
            
            <form class="newsletter-form" action="/newsletter/subscribe" method="POST">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                <input type="email" name="email" placeholder="Enter your email address" required>
                <button type="submit" class="btn-subscribe">Subscribe</button>
            </form>
        </div>
    </section>
    <%- include('partials/footer') %>

</body>
</html>