<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('partials/head') %>
    <title>Reset Password | Libas-e-Ikhlaq</title>
</head>
<body class="auth-page">

    <div class="container-fluid p-0">
        <div class="row g-0 min-vh-100 flex-lg-row-reverse">
            
            <div class="col-12 col-lg-6 auth-image-side d-flex flex-column justify-content-center align-items-center text-center p-5" style="background: linear-gradient(rgba(0,0,0,0.5), rgba(0,0,0,0.7)), url('/maroonkurta.png') center/cover no-repeat; min-height: 40vh;">
                <h1 class="auth-brand-title text-white">RESET ACCESS</h1>
                <p class="auth-brand-tagline text-white">Choose a strong password containing numbers and uppercase characters to secure your shop profile.</p>
            </div>

            <div class="col-12 col-lg-6 auth-form-side d-flex flex-column justify-content-center position-relative p-4 p-md-5 bg-white">
                <a href="/login" class="back-btn mb-4 d-inline-block text-decoration-none text-dark fw-bold"><i class="fa-solid fa-arrow-left"></i> Cancel</a>

                <div class="auth-form-wrapper mx-auto" style="max-width: 450px; width: 100%;">
                    <h2 class="mb-2">Set New Password</h2>
                    <p class="text-muted mb-4">Please input your new credentials below to finalize password reset.</p>

                    <% if (locals.error_msg && error_msg.length > 0) { %>
                        <div class="alert alert-danger"><%= error_msg %></div>
                    <% } %>

                    <form action="/reset-password/<%= token %>" method="POST">
                        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                        
                        <div class="mb-3">
                            <label for="reset-password" class="form-label">New Password</label>
                            <input type="password" class="form-control" id="reset-password" name="password" minlength="6" placeholder="Min. 6 chars, 1 uppercase, 1 digit" required>
                        </div>
                        <div class="mb-4">
                            <label for="confirm-password" class="form-label">Confirm New Password</label>
                            <input type="password" class="form-control" id="confirm-password" name="confirmPassword" minlength="6" placeholder="Re-enter new password" required>
                        </div>
                        
                        <button type="submit" class="btn btn-dark w-100 py-2 fw-bold" style="background-color: var(--brand-orange); border-color: var(--brand-orange);">SAVE PASSWORD</button>
                    </form>
                </div>
            </div>
        </div>
    </div>

</body>
</html>
